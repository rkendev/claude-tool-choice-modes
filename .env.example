# claude-tool-choice-modes — environment variables
#
# Copy to `.env` (which is gitignored) and fill in real values for the tiers
# you want active. Missing keys cause their adapter to raise LLMPermanentError
# at construction time (fail-fast, per SPECIFICATION §5).
#
# `.env` is loaded by pydantic-settings (D4). Keys are wrapped in SecretStr so
# `print(config)` does not leak them.

# --- Primary tier: Anthropic Claude Haiku ---
# Required for the PRIMARY tier. Leave blank to skip Claude entirely.
ANTHROPIC_API_KEY=
# Override to point the PRIMARY tier at a different Claude model.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Secondary tier: OpenAI gpt-4o-mini ---
# Required for the SECONDARY tier. Leave blank to skip OpenAI entirely.
OPENAI_API_KEY=
# Override to point the SECONDARY tier at a different OpenAI model.
OPENAI_MODEL=gpt-4o-mini

# --- Tertiary tier: local Ollama ---
# Always available when docker compose is running ollama.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Shared adapter behaviour ---
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# --- Observability ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Example CLI (examples/hello_llm) ---
# One of: primary, secondary, tertiary, fallback
# `fallback` runs the three-tier FallbackModel composition.
LLM_TIER=fallback
